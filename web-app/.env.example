# Tilder server environment

# Local Node server port
PORT=3210

# Public URL used to build OAuth callback URLs.
# Local dev:
# PUBLIC_BASE_URL=http://localhost:3210
# Render production:
# PUBLIC_BASE_URL=https://tildercode.onrender.com
PUBLIC_BASE_URL=https://tilder-web-app.onrender.com/

# Optional overrides
# GIT_BINARY=git
# TILDER_RUNNER_URL=https://ce.judge0.com
# TILDER_TERMINAL_CWD=D:\Tilder\web-app

# GitHub OAuth
# Recommended: use one GitHub OAuth app for local dev and another for production,
# because GitHub OAuth apps allow only one callback URL per app.
GITHUB_CLIENT_ID=GITHUB_CLIENT_ID=Ov23liKYnzbU4R2MOfaO
GITHUB_CLIENT_SECRET=e070ecdf71974ca84c1dc83d5acd49e8f57ca10d

# Microsoft OAuth
# Microsoft app registrations can carry multiple redirect URIs.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
