{
  "name": "web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node server.js",
    "start": "node server.js",
    "terminal-bridge": "node terminal-bridge.js",
    "tilderx": "node scripts/tilderx.mjs",
    "build:desktop": "npm run build && node scripts/prepare-tauri-runtime.mjs",
    "sync:snippets": "node scripts/sync-friendly-snippets.mjs",
    "sync:completions": "node scripts/sync-monaco-completions.mjs",
    "build": "vite build",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@fortawesome/fontawesome-svg-core": "^6.4.2",
    "@fortawesome/free-brands-svg-icons": "^6.4.2",
    "@fortawesome/free-regular-svg-icons": "^6.4.2",
    "@fortawesome/free-solid-svg-icons": "^6.4.2",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@monaco-editor/react": "^4.5.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bootstrap": "^5.3.2",
    "dotenv": "^17.3.1",
    "emmet-monaco-es": "^5.7.0",
    "express": "^5.2.1",
    "moment": "^2.30.1",
    "monaco-themes": "^0.4.4",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.8.0",
    "react-dom": "^18.2.0",
    "react-file-icon": "^1.6.0",
    "react-icons": "^5.6.0",
    "simple-git": "^3.33.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^18.0.37",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react-swc": "^3.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.38.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "gh-pages": "^6.1.1",
    "vite": "^4.5.9"
  }
}
